# Environment Variables for Solar Panel Fault Detection

# Model Configuration
MODEL_TYPE=resnet50
MODEL_WEIGHTS=models/checkpoints/best_model.pth

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard Configuration
DASHBOARD_PORT=8501

# Kaggle API Credentials (optional)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Weights & Biases (optional)
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=solar-panel-fault-detection

# MLflow (optional)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=solar_panel_fault_detection

# CUDA Configuration
CUDA_VISIBLE_DEVICES=0

# Logging
LOG_LEVEL=INFO
